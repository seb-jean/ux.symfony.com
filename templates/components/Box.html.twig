{% set attr_style = [
    '--color: ' ~ color,
    '--gradient: ' ~ gradient ?: 'none',
    '--logo-size: ' ~ logoSize ?? '6rem',
]|join(' ;') %}

<div
    class="group relative flex gap-6 p-6 self-stretch border border-surface rounded-md bg-body transition-all duration-750 ease-in-out hover:-translate-y-1 hover:duration-200 before:content-[''] before:absolute before:top-1 before:inset-x-0 before:-bottom-1 before:rounded-md before:opacity-0 before:blur-md before:-z-10 before:transition-opacity before:duration-600 before:[background-image:var(--gradient)] before:bg-black/50 hover:before:opacity-25 hover:before:duration-250 after:content-[''] after:absolute after:inset-0 after:rounded-md after:bg-body after:-z-10 after:opacity-95 after:transition-opacity after:duration-600 hover:after:opacity-[0.99] hover:after:duration-250"
    style="{{ attr_style }}"
>
    {% block badge %}{% endblock %}

    <div class="flex items-center justify-center shrink-0 rounded-[14%] [background-image:var(--gradient)] bg-(--color) w-(--logo-size) h-(--logo-size) [&_img]:w-[calc(0.4*var(--logo-size))] [&_img]:h-auto [&_img]:transition-all [&_img]:duration-600 [&_img]:filter-drop-shadow group-hover:[&_img]:filter-drop-shadow-lg group-hover:[&_img]:scale-105 group-hover:[&_img]:duration-250">
        {% block logo %}{% endblock %}
    </div>

    <div class="flex flex-col justify-center flex-1">
        <{{ titleTag }} class="flex flex-row items-center gap-3 font-title font-bold text-2xl leading-normal text-body-text m-0 {{ titleClass }}">
            {% block title %}{% endblock %}
        </{{ titleTag }}>
        {% block description %}{% endblock %}
    </div>
</div>
