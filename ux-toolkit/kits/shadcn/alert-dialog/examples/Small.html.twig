<twig:AlertDialog id="alert-small">
    <twig:AlertDialog:Trigger>
        <twig:Button variant="outline" {{ ...trigger_attrs }}>Show Small Dialog</twig:Button>
    </twig:AlertDialog:Trigger>
    <twig:AlertDialog:Content class="sm:max-w-sm">
        <twig:AlertDialog:Header>
            <twig:AlertDialog:Title>Delete file?</twig:AlertDialog:Title>
            <twig:AlertDialog:Description>
                This file will be permanently deleted.
            </twig:AlertDialog:Description>
        </twig:AlertDialog:Header>
        <twig:AlertDialog:Footer>
            <twig:AlertDialog:Cancel>Cancel</twig:AlertDialog:Cancel>
            <twig:AlertDialog:Action>Delete</twig:AlertDialog:Action>
        </twig:AlertDialog:Footer>
    </twig:AlertDialog:Content>
</twig:AlertDialog>
