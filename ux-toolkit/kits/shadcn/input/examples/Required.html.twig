<div class="w-full max-w-sm">
    <twig:Field:Group>
        <twig:Field>
            <twig:Field:Label for="req-name">Full name <span class="text-destructive" aria-hidden="true">*</span></twig:Field:Label>
            <twig:Input id="req-name" type="text" placeholder="John Doe" required />
        </twig:Field>
        <twig:Field>
            <twig:Field:Label for="req-email">Email <span class="text-destructive" aria-hidden="true">*</span></twig:Field:Label>
            <twig:Input id="req-email" type="email" placeholder="m@example.com" required />
        </twig:Field>
        <twig:Field>
            <twig:Field:Label for="req-company">Company</twig:Field:Label>
            <twig:Input id="req-company" type="text" placeholder="Acme Inc." />
        </twig:Field>
    </twig:Field:Group>
</div>
