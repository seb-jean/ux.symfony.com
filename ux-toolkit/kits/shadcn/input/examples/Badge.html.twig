<div class="w-full max-w-sm">
    <twig:Field:Group>
        <twig:Field>
            <twig:Field:Label for="badge-username">
                Username <twig:Badge variant="secondary">Recommended</twig:Badge>
            </twig:Field:Label>
            <twig:Input id="badge-username" type="text" placeholder="@johndoe" />
            <twig:Field:Description>
                Your public display name.
            </twig:Field:Description>
        </twig:Field>
        <twig:Field>
            <twig:Field:Label for="badge-website">
                Website <twig:Badge variant="outline">Optional</twig:Badge>
            </twig:Field:Label>
            <twig:Input id="badge-website" type="url" placeholder="https://example.com" />
        </twig:Field>
    </twig:Field:Group>
</div>
