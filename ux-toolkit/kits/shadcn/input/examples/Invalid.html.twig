<div class="w-full max-w-sm">
    <twig:Field data-invalid>
        <twig:Field:Label for="email-invalid">Email</twig:Field:Label>
        <twig:Input id="email-invalid" type="email" placeholder="m@example.com" aria-invalid="true" />
        <twig:Field:Error>Please enter a valid email address.</twig:Field:Error>
    </twig:Field>
</div>
