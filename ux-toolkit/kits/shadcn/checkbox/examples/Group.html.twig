<div class="flex flex-col gap-3">
    <twig:Label class="text-base font-medium">Notifications</twig:Label>
    <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2">
            <twig:Checkbox id="group-email" checked />
            <twig:Label for="group-email">Email notifications</twig:Label>
        </div>
        <div class="flex items-center gap-2">
            <twig:Checkbox id="group-sms" />
            <twig:Label for="group-sms">SMS notifications</twig:Label>
        </div>
        <div class="flex items-center gap-2">
            <twig:Checkbox id="group-push" checked />
            <twig:Label for="group-push">Push notifications</twig:Label>
        </div>
    </div>
</div>
